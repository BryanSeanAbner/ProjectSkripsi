APP_NAME="Sistem Rekomendasi Berita"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite lokal — hanya untuk session, cache, dan queue Laravel
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# sync = job rekomendasi jalan langsung saat login (tanpa php artisan queue:work)
QUEUE_CONNECTION=sync

CACHE_STORE=database

# Supabase — database utama aplikasi (users, article, rekomendasi, dll.)
